# ============================================================
# TheFortFX Backend — Environment Variables
# Copy this file to .env and fill in real values
# ============================================================

# --- App Settings ------------------------------------------------
APP_NAME=TheFortFX
APP_ENV=development
APP_URL=https://thefortfx.com
API_URL=https://api.thefortfx.com
SECRET_KEY=change-me-openssl-rand-hex-32
DEBUG=true

# --- Supabase ----------------------------------------------------
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# --- Database (PostgreSQL + asyncpg) -----------------------------
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/thefortfx
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# --- Redis --------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL_SIGNALS=900
REDIS_CACHE_TTL_FORECASTS=3600
REDIS_CACHE_TTL_SENTIMENT=1800
REDIS_CACHE_TTL_CALENDAR=3600
REDIS_CACHE_TTL_OPPORTUNITIES=600

# --- Celery -------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- AI Providers -------------------------------------------------
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- External Data Sources ----------------------------------------
FOREX_FACTORY_RSS_URL=https://nfs.faireconomy.media/ff_calendar_thisweek.json
ALPHA_VANTAGE_API_KEY=
TWELVE_DATA_API_KEY=
NEWS_API_KEY=

# --- Telegram Notifications --------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# --- Email (Resend) -----------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@thefortfx.com

# --- Payments (Stripe) -------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_AGENCY=

# --- SEO / IndexNow ----------------------------------------------
INDEXNOW_KEY=

# --- Monitoring (Sentry) -----------------------------------------
SENTRY_DSN=

# --- Security / Rate Limiting ------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=5
